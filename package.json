{
  "name": "@opensea/stream-js",
  "version": "0.3.0",
  "description": "A TypeScript SDK to receive pushed updates from OpenSea over websocket",
  "license": "MIT",
  "author": "OpenSea Developers",
  "homepage": "https://docs.opensea.io/reference/stream-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProjectOpenSea/stream-js.git"
  },
  "bugs": {
    "url": "https://github.com/ProjectOpenSea/stream-js/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "coverage": "vitest run --coverage",
    "dev": "tsup --watch",
    "format": "biome format --config-path . --write .",
    "format:check": "biome format --config-path . .",
    "lint": "biome check --config-path . .",
    "lint:fix": "biome check --config-path . --write .",
    "prepublish": "npm run build",
    "test": "vitest run"
  },
  "sideEffects": false,
  "dependencies": {
    "phoenix": "^1.6.15"
  },
  "devDependencies": {
    "@types/phoenix": "^1.5.6",
    "@types/ws": "^8.5.4",
    "concurrently": "^9.2.1",
    "jsdom": "^26.0.0",
    "ts-node": "^10.9.1",
    "tsup": "^8.3.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4",
    "@biomejs/biome": "^2.4.10"
  },
  "keywords": [
    "collectibles",
    "crypto",
    "ethereum",
    "javascript",
    "marketplace",
    "nft",
    "node",
    "non-fungible-tokens",
    "opensea",
    "project-opensea",
    "sdk",
    "smart-contracts",
    "typescript",
    "websocket"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "source": "src/index.ts"
}
